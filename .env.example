DATABASE_URL="postgresql://postgres:postgres@localhost:5432/financial_assistant?schema=public"

# Runtime target: web | android | desktop
NEXT_PUBLIC_APP_PLATFORM="web"

# Environment mode: development | production
NEXT_PUBLIC_APP_ENV="development"

# API mode: cloud | local | mock
NEXT_PUBLIC_API_MODE="cloud"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api"

# Desktop mode: cloud | local
NEXT_PUBLIC_DESKTOP_DATA_MODE="cloud"

# Static export for Capacitor/Tauri shell builds.
# Set NEXT_OUTPUT="export" only when an external/local API adapter is used.
NEXT_OUTPUT=""
