# Docker Compose env for the WEB deploy. On the server: copy to `.env` and fill in.
#   cp .env.docker.example .env

# Postgres password — REQUIRED (compose fails fast if unset). Use a strong, unique
# value. The DB is only on the internal compose network. Rotate on any suspected
# exposure: change here, then `docker compose up -d` (the data volume persists).
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
POSTGRES_PASSWORD=""

# NextAuth session secret — REQUIRED. A leak lets an attacker forge any session,
# so keep it unique per environment and rotate if exposed (invalidates sessions).
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Optional: enables the AI assistant on the web (/api/ai/parse) with a server key.
ANTHROPIC_API_KEY=""

# Optional: error monitoring — set to your Sentry DSN to enable.
SENTRY_DSN=""

# Optional: encrypt nightly DB backups at rest (AES-256). Strongly recommended —
# dumps contain all user PII. Store this key OFF the server (not next to backups).
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Decrypt later:  openssl enc -d -aes-256-cbc -pbkdf2 -pass env:BACKUP_ENCRYPTION_KEY -in db-*.sql.gz.enc | gunzip
BACKUP_ENCRYPTION_KEY=""

# The app is served only via Caddy over HTTPS (https://<server-ip>). The web
# container is not host-published, so there is no plain-HTTP WEB_PORT anymore.
