# Docker Compose env for the WEB deploy. On the server: copy to `.env` and fill in.
#   cp .env.docker.example .env

# Postgres password (use a strong value; the DB is only on the internal network).
POSTGRES_PASSWORD="change-me-strong-password"

# NextAuth session secret — REQUIRED. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Optional: enables the AI assistant on the web (/api/ai/parse) with a server key.
ANTHROPIC_API_KEY=""

# Optional: error monitoring — set to your Sentry DSN to enable.
SENTRY_DSN=""

# Public port. App will be at http://<server-ip>:<WEB_PORT>
WEB_PORT="3000"
