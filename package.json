{
  "name": "financial-assistant-mvp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_PUBLIC_MARKET_DATA=moex next dev",
    "build": "next build",
    "build:web": "cross-env NEXT_PUBLIC_APP_PLATFORM=web NEXT_PUBLIC_MARKET_DATA=moex next build",
    "build:static": "cross-env NEXT_PUBLIC_APP_PLATFORM=desktop NEXT_PUBLIC_DESKTOP_DATA_MODE=local NEXT_PUBLIC_API_MODE=local NEXT_PUBLIC_MARKET_DATA=moex NEXT_OUTPUT=export next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "docker:db:up": "docker compose up -d postgres",
    "docker:db:down": "docker compose down",
    "docker:db:logs": "docker compose logs -f postgres",
    "tauri": "tauri",
    "tauri:dev": "node scripts/tauri-with-rust-path.mjs dev",
    "tauri:build": "node scripts/tauri-with-rust-path.mjs build",
    "desktop:icons": "powershell -ExecutionPolicy Bypass -File scripts/generate-tauri-icons.ps1",
    "desktop:preflight": "node scripts/desktop-preflight.mjs",
    "cap:sync": "cap sync",
    "cap:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.3",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.3",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^20.17.6",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
