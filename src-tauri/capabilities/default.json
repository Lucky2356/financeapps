{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Desktop permissions for CSV/JSON import/export and cloud-folder sync.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state",
    "updater:default",
    "process:allow-restart",
    "opener:allow-open-url",
    {
      "identifier": "fs:scope",
      "allow": ["$DESKTOP/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$HOME/**"]
    }
  ]
}
