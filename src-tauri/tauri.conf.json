{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Финансовый помощник",
  "version": "1.2.0",
  "identifier": "ru.lucky2356.financeapps",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:static",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Финансовый помощник",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://iss.moex.com https://www.cbr.ru https://api.anthropic.com https://api.openai.com https://api.deepseek.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Lucky2356/financeapps/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3NUFDOTcyMzIyRUI1OTYKUldTV3RTNHljc2xhOTJhWm5QNlhUNUVDbWMwSHY5TnJ5WUh2cHU1NXRUeXorKytWMXdLdE05YU4K"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Russian", "English"]
      }
    }
  }
}
