{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Финансовый помощник",
  "version": "0.1.0",
  "identifier": "ru.finassistant.mvp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:static",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Финансовый помощник",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../public/icons/icon.svg"]
  }
}
