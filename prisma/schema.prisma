generator client {
  provider      = "prisma-client-js"
  // native = local dev; linux-musl-openssl-3.0.x = the Alpine Docker image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum AccountType {
  CASH
  DEBIT_CARD
  SAVINGS
  BROKERAGE
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum RecommendationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum SecurityRisk {
  LOW
  MEDIUM
  HIGH
}

enum RiskProfileCode {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum ExternalConnectionStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

model RiskProfile {
  id                     String          @id @default(cuid())
  code                   RiskProfileCode @unique
  title                  String
  description            String
  maxHighRiskShare       Decimal         @db.Decimal(5, 2)
  maxSinglePositionShare Decimal         @db.Decimal(5, 2)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  users                  User[]
}

model User {
  id                        String               @id @default(cuid())
  email                     String               @unique
  name                      String
  passwordHash              String?
  currency                  String               @default("RUB")
  demoMode                  Boolean              @default(true)
  emergencyFundMonthsTarget Int                  @default(6)
  theme                     String               @default("system")
  density                   String               @default("comfortable")
  defaultTransactionType    TransactionType      @default(EXPENSE)
  autoMaterializeRecurring  Boolean              @default(false)
  paymentReminders          Boolean              @default(false)
  aiEnabled                 Boolean              @default(false)
  aiApiKey                  String?
  aiModel                   String?
  riskProfileId             String?
  riskProfile               RiskProfile?         @relation(fields: [riskProfileId], references: [id])
  accounts                  Account[]
  categories                Category[]
  transactions              Transaction[]
  budgets                   Budget[]
  savingGoals               SavingGoal[]
  liabilities               Liability[]
  recommendations           Recommendation[]
  portfolios                Portfolio[]
  watchlistItems            WatchlistItem[]
  recurringTransactions     RecurringTransaction[]
  externalConnections       ExternalConnection[]
  netWorthSnapshots         NetWorthSnapshot[]
  rules                     Rule[]
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  @@index([riskProfileId])
}

model Account {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         AccountType
  balance      Decimal       @default(0) @db.Decimal(14, 2)
  currency     String        @default("RUB")
  isArchived   Boolean       @default(false)
  transactions Transaction[]
  recurringTransactions RecurringTransaction[]
  portfolios   Portfolio[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
}

model Category {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  kind           CategoryKind
  color          String        @default("#2563eb")
  icon           String        @default("Circle")
  isEssential    Boolean       @default(false)
  isSubscription Boolean       @default(false)
  transactions   Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets        Budget[]
  rules          Rule[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([userId, name, kind])
  @@index([userId, kind])
}

// User-defined auto-categorization rule: "if a transaction description contains
// `match`, assign `category`". Web mirror of the desktop local-state rules; rules
// take priority over the history-based suggestion (see lib/category-suggest.ts).
model Rule {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([categoryId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amount      Decimal         @db.Decimal(14, 2)
  type        TransactionType
  date        DateTime
  description String?
  // Groups transactions created by a single CSV import so the import can be
  // undone as a unit (web parity with the desktop local-state importBatches).
  importBatchId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId, date])
  @@index([accountId])
  @@index([categoryId])
  @@index([type])
  @@index([userId, importBatchId])
}

model RecurringTransaction {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amount        Decimal             @db.Decimal(14, 2)
  type          TransactionType
  frequency     RecurrenceFrequency
  nextDate      DateTime
  description   String?
  isActive      Boolean             @default(true)
  lastCreatedAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId, isActive, nextDate])
  @@index([accountId])
  @@index([categoryId])
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  month       DateTime
  limitAmount Decimal  @db.Decimal(14, 2)
  // When true, the previous month's unspent remainder is added to this month's
  // available limit (single-month carryover).
  rollover    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}

model SavingGoal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  targetAmount  Decimal  @db.Decimal(14, 2)
  currentAmount Decimal  @default(0) @db.Decimal(14, 2)
  deadline      DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, deadline])
}

enum LiabilityKind {
  CREDIT_CARD
  LOAN
  MORTGAGE
  INSTALLMENT
  OTHER
}

model Liability {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  kind           LiabilityKind @default(OTHER)
  balance        Decimal       @default(0) @db.Decimal(14, 2)
  originalAmount Decimal       @default(0) @db.Decimal(14, 2)
  interestRate   Decimal       @default(0) @db.Decimal(6, 2)
  minPayment     Decimal       @default(0) @db.Decimal(14, 2)
  dueDay         Int?
  currency       String        @default("RUB")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
}

// Daily captured net worth (plan B7) — real value incl. portfolio market value,
// so the capital trend is accurate going forward instead of flow-reconstructed.
model NetWorthSnapshot {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String // YYYY-MM-DD (local day)
  value  Decimal @db.Decimal(16, 2)

  @@unique([userId, date])
  @@index([userId, date])
}

model Recommendation {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  severity    RecommendationSeverity @default(INFO)
  metadata    Json?
  dismissed   Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([userId, severity])
}

model Security {
  id             String              @id @default(cuid())
  ticker         String              @unique
  name           String
  sector         String
  risk           SecurityRisk
  comment        String
  prices         MarketPrice[]
  positions      PortfolioPosition[]
  watchlistItems WatchlistItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model MarketPrice {
  id         String   @id @default(cuid())
  securityId String
  security   Security @relation(fields: [securityId], references: [id], onDelete: Cascade)
  date       DateTime
  price      Decimal  @db.Decimal(14, 4)
  changeDay  Decimal  @default(0) @db.Decimal(8, 4)
  change30d  Decimal  @default(0) @db.Decimal(8, 4)
  source     String   @default("MOCK")
  createdAt  DateTime @default(now())

  @@unique([securityId, date])
  @@index([securityId, date])
}

model Portfolio {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String?
  account     Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  name        String
  positions   PortfolioPosition[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId])
}

model PortfolioPosition {
  id              String    @id @default(cuid())
  portfolioId     String
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  securityId      String
  security        Security  @relation(fields: [securityId], references: [id], onDelete: Cascade)
  quantity        Decimal   @db.Decimal(18, 6)
  averageBuyPrice Decimal   @db.Decimal(14, 4)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([portfolioId, securityId])
  @@index([securityId])
}

model WatchlistItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  securityId String
  security   Security @relation(fields: [securityId], references: [id], onDelete: Cascade)
  notes      String?
  createdAt  DateTime @default(now())

  @@unique([userId, securityId])
  @@index([userId])
}

model ExternalConnection {
  id                    String                   @id @default(cuid())
  userId                String
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              String
  status                ExternalConnectionStatus @default(DISCONNECTED)
  /// Banking API access requires official provider access and explicit user consent.
  /// If tokens are added later, they must be encrypted at rest and rotated safely.
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  connectedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([userId, provider])
}
